<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header info: Title & Percentage -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Main Savings Goal"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- Subtitle: Amounts -->
    <TextView
        android:id="@+id/widget_amount_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="$0 of $0 saved"
        android:textSize="11sp"
        android:textColor="#8D9199"
        android:layout_marginBottom="8dp" />

    <!-- Grid View Canvas (Always Perfect Square, Never Cuts Off) -->
    <ImageView
        android:id="@+id/widget_grid_canvas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:layout_marginBottom="10dp" />

    <!-- Interactive Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Button: -$10 -->
        <TextView
            android:id="@+id/widget_btn_sub10"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_button_bg"
            android:text="-$10"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#E0E0E0"
            android:focusable="true"
            android:clickable="true" />

        <!-- Button: +$10 -->
        <TextView
            android:id="@+id/widget_btn_add10"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_button_bg"
            android:text="+$10"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:focusable="true"
            android:clickable="true" />

        <!-- Button: +$50 -->
        <TextView
            android:id="@+id/widget_btn_add50"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_button_bg"
            android:text="+$50"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:focusable="true"
            android:clickable="true" />

        <!-- Button: Open -->
        <TextView
            android:id="@+id/widget_btn_open"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_bg"
            android:text="Open"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#E0E0E0"
            android:focusable="true"
            android:clickable="true" />
    </LinearLayout>
</LinearLayout>
